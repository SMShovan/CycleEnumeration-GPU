PROJECT_NAME           = "CycleEnumeration-GPU"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
PROJECT_BRIEF          = "Single-node CPU and CUDA cycle enumeration"

OUTPUT_DIRECTORY       = "@PROJECT_SOURCE_DIR@/docs/doxygen"
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO
OUTPUT_LANGUAGE        = English

INPUT                  = "@PROJECT_SOURCE_DIR@/include" \
                         "@PROJECT_SOURCE_DIR@/src" \
                         "@PROJECT_SOURCE_DIR@/docs/doxygen/modules.dox" \
                         "@PROJECT_SOURCE_DIR@/docs/design" \
                         "@PROJECT_SOURCE_DIR@/README.md"
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp *.cpp *.cuh *.cu *.md *.dox
USE_MDFILE_AS_MAINPAGE = "@PROJECT_SOURCE_DIR@/README.md"

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_XML           = NO

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_FROM_PATH        = "@PROJECT_SOURCE_DIR@"

JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = NO

